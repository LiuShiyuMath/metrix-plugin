#!/usr/bin/env bash
# plugins/teamagent-team-sync/bin/teamagent-share
#
# SHARE: turn the local ~/.claude "main contents" into a detailed, PUBLIC,
# secret-redacted setup manifest and publish it — either as a public gist
# (default) or into a public personal repo (--repo owner/name).
#
# This is a FIXED TOOL. No LLM is in the path: the manifest is assembled
# mechanically by bash+jq and the secret redaction is a deterministic
# filter, so the judge harness can run it and diff its JSON. Per
# metrixMarkets EVAL.md the LLM may only read the JSON this prints.
#
# Why a manifest and not a raw dump: ~/.claude/CLAUDE.md and settings.json
# routinely carry machine IPs, Slack/GitHub tokens, API keys. A prior
# attempt to publish raw ~/.claude content was (correctly) auto-blocked by
# the data-exfiltration policy. So we publish the *shareable surface* in
# full detail — every skill, plugin, agent, command, hook, and the CLAUDE.md
# structure — with mechanical secret redaction and an explicit redaction
# count. Detailed enough for a teammate to replicate; safe to make public.
#
# Usage:
#   teamagent-share [--public|--secret] [--repo owner/name] [--out DIR]
#                   [--dry-run] [--claude-home DIR]
#
#   --public      gist is public/listed on profile (DEFAULT — sharing is the point)
#   --secret      gist is link-only (unlisted)
#   --repo o/n    push manifest to a public personal repo instead of a gist
#   --out DIR     where to write the manifest before publish (default: mktemp)
#   --dry-run     build + print the manifest + JSON summary, DO NOT publish
#   --claude-home use this dir instead of ~/.claude (testing)
#
# Output: human-readable progress on stderr; the LAST stdout line is one
# JSON object: {ok, mode, scope_counts, redactions, manifest_md,
# manifest_json, share_url, raw_url, dry_run}. Exit 0 always (probe-safe);
# read .ok, never the exit code.

set -u

CLAUDE_HOME="${HOME}/.claude"
VIS="--public"
REPO=""
OUT=""
DRY=0

while [ $# -gt 0 ]; do
  case "$1" in
    --public) VIS="--public" ;;
    --secret) VIS="" ;;
    --repo) REPO="${2:-}"; shift ;;
    --out) OUT="${2:-}"; shift ;;
    --dry-run) DRY=1 ;;
    --claude-home) CLAUDE_HOME="${2:-}"; shift ;;
    -h|--help) sed -n '2,40p' "$0"; exit 0 ;;
    *) echo "teamagent-share: unknown arg: $1" >&2 ;;
  esac
  shift
done

emit() { # $1 = compact JSON ; always the last stdout line
  printf '%s\n' "$1"
}

fail_json() { # $1 = reason
  if command -v jq >/dev/null 2>&1; then
    jq -nc --arg r "$1" '{ok:false, reason:$r, dry_run:false}'
  else
    printf '{"ok":false,"reason":"%s","dry_run":false}\n' "$1"
  fi
  exit 0
}

command -v jq >/dev/null 2>&1 || fail_json "jq not found (hard dep per EVAL.md)"
[ -d "$CLAUDE_HOME" ] || fail_json "no such claude home: $CLAUDE_HOME"

WORK="${OUT:-$(mktemp -d 2>/dev/null || echo /tmp/teamagent-share.$$)}"
mkdir -p "$WORK" || fail_json "cannot create work dir: $WORK"
MD="$WORK/claude-setup.md"
JSON="$WORK/claude-setup.json"

# ---------------------------------------------------------------------------
# Deterministic secret redactor. Operates line-wise. A line is dropped (not
# partially masked — masking is unreliable) and counted if it matches any
# credential signature. Stdin -> stdout; prints redaction count to fd 3.
# ---------------------------------------------------------------------------
# Case-insensitive. Token bodies allow - and _ (real keys like
# sk-ant-api03-… and github_pat_… contain them). The key=value arm catches
# camelCase names (apiKey) too because the whole match is case-insensitive.
REDACT_RE='(sk-[a-z0-9_-]{8,}|xox[baprs]-[a-z0-9-]{8,}|ghp_[a-z0-9]{16,}|github_pat_[a-z0-9_]{16,}|gh[opsu]_[a-z0-9]{16,}|akia[0-9a-z]{12,}|-----begin [a-z ]*private key-----|bearer [a-z0-9._-]{12,}|("?(api[_-]?key|secret|password|passwd|token|client[_-]?secret|authorization|access[_-]?token|xoxc|cookie)"?[[:space:]]*[:=][[:space:]]*"?[^"[:space:]]{6,}))'

redact_stream() { # reads stdin, writes redacted stdout, count -> $REDACT_COUNT_FILE
  local n=0
  while IFS= read -r ln || [ -n "$ln" ]; do
    if printf '%s' "$ln" | grep -Eiq "$REDACT_RE"; then
      n=$((n + 1))
      printf '%s\n' "    [REDACTED — potential secret, 1 line]"
    else
      printf '%s\n' "$ln"
    fi
  done
  echo "$n" > "$REDACT_COUNT_FILE"
}
REDACT_COUNT_FILE="$WORK/.redactions"
echo 0 > "$REDACT_COUNT_FILE"

# ---------------------------------------------------------------------------
# Collectors — every one is an inventory of the shareable surface.
# ---------------------------------------------------------------------------
list_dir_names() { # $1 dir ; prints basenames of immediate entries, sorted
  [ -d "$1" ] || return 0
  find "$1" -mindepth 1 -maxdepth 1 -exec basename {} \; 2>/dev/null | LC_ALL=C sort
}

skill_lines() { # name<TAB>first description line
  local sk d nm desc
  for sk in "$CLAUDE_HOME"/skills "$CLAUDE_HOME"/skills/*/; do :; done
  if [ -d "$CLAUDE_HOME/skills" ]; then
    while IFS= read -r d; do
      [ -n "$d" ] || continue
      nm="$(basename "$d")"
      desc=""
      if [ -f "$d/SKILL.md" ]; then
        desc="$(grep -m1 -E '^description:' "$d/SKILL.md" 2>/dev/null | sed -E 's/^description:[[:space:]]*//; s/"//g' | cut -c1-160)"
      fi
      printf '%s\t%s\n' "$nm" "${desc:-—}"
    done < <(find "$CLAUDE_HOME/skills" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | LC_ALL=C sort)
  fi
}

plugin_lines() {
  local f="$CLAUDE_HOME/plugins/installed_plugins.json"
  if [ -f "$f" ]; then
    jq -r '
      (if type=="object" then (.plugins // . ) else . end)
      | (if type=="array" then .[] else (to_entries[]|.value + {name:(.key)}) end)
      | [ (.name // .id // "unknown"), (.marketplace // .source // .repo // "") ]
      | @tsv
    ' "$f" 2>/dev/null | LC_ALL=C sort -u
  fi
}

n_skills=$(skill_lines | grep -c . || true)
n_plugins=$(plugin_lines | grep -c . || true)
n_agents=$(list_dir_names "$CLAUDE_HOME/agents" | grep -c . || true)
n_cmds=$(find "$CLAUDE_HOME/commands" -maxdepth 1 -name '*.md' 2>/dev/null | grep -c . || true)

# ---------------------------------------------------------------------------
# Build the Markdown manifest.
# ---------------------------------------------------------------------------
GEN_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
{
  echo "# Claude Code setup — shareable manifest"
  echo
  echo "> Generated by \`teamagent-team-sync\` (\`teamagent-share\`) at ${GEN_AT}."
  echo "> This is the **shareable surface** of \`~/.claude\`, secret-redacted."
  echo "> A teammate can replicate this setup with the one-click install prompt"
  echo "> at the bottom (or via \`teamagent-install-prompt\`)."
  echo
  echo "| surface | count |"
  echo "|---|---|"
  echo "| skills | ${n_skills} |"
  echo "| plugins | ${n_plugins} |"
  echo "| agents | ${n_agents} |"
  echo "| commands | ${n_cmds} |"
  echo
  echo "## Plugins"
  echo
  if [ "${n_plugins}" -gt 0 ]; then
    echo '```'
    plugin_lines | while IFS=$'\t' read -r nm mk; do
      printf '%s  (marketplace: %s)\n' "$nm" "${mk:-?}"
    done
    echo '```'
  else
    echo "_none installed_"
  fi
  echo
  echo "## Skills"
  echo
  if [ "${n_skills}" -gt 0 ]; then
    skill_lines | while IFS=$'\t' read -r nm desc; do
      printf -- '- **%s** — %s\n' "$nm" "$desc"
    done
  else
    echo "_none_"
  fi
  echo
  echo "## Agents"
  echo
  list_dir_names "$CLAUDE_HOME/agents" | sed 's/\.md$//' | while read -r a; do
    [ -n "$a" ] && printf -- '- %s\n' "$a"
  done
  echo
  echo "## Commands"
  echo
  find "$CLAUDE_HOME/commands" -maxdepth 1 -name '*.md' 2>/dev/null | LC_ALL=C sort \
    | while read -r c; do [ -n "$c" ] && printf -- '- /%s\n' "$(basename "$c" .md)"; done
  echo
  echo "## CLAUDE.md structure (headings only — prose withheld for safety)"
  echo
  if [ -f "$CLAUDE_HOME/CLAUDE.md" ]; then
    echo '```'
    grep -E '^#{1,6} ' "$CLAUDE_HOME/CLAUDE.md" 2>/dev/null | cut -c1-120 | head -n 200
    echo '```'
  else
    echo "_no ~/.claude/CLAUDE.md_"
  fi
  echo
  echo "## settings.json (secret-redacted)"
  echo
  echo '```json'
  if [ -f "$CLAUDE_HOME/settings.json" ]; then
    jq -S . "$CLAUDE_HOME/settings.json" 2>/dev/null | redact_stream || echo "  (unparseable settings.json — withheld)"
  else
    echo "  (no settings.json)"
  fi
  echo '```'
} > "$MD"

REDACTIONS="$(cat "$REDACT_COUNT_FILE" 2>/dev/null || echo 0)"
{
  echo
  echo "---"
  echo
  echo "**Redactions:** ${REDACTIONS} line(s) withheld as potential secrets."
  echo "Raw credentials, \`.env\`, \`.credentials.json\`, and \`*.key\` are never collected."
} >> "$MD"

# Machine-readable twin.
jq -nc \
  --arg gen "$GEN_AT" \
  --argjson sk "${n_skills:-0}" \
  --argjson pl "${n_plugins:-0}" \
  --argjson ag "${n_agents:-0}" \
  --argjson cm "${n_cmds:-0}" \
  --argjson rd "${REDACTIONS:-0}" \
  '{generated_at:$gen, counts:{skills:$sk,plugins:$pl,agents:$ag,commands:$cm}, redactions:$rd, schema:"teamagent-claude-setup/v1"}' \
  > "$JSON"

# ---------------------------------------------------------------------------
# Publish.
# ---------------------------------------------------------------------------
SCOPE_JSON="$(jq -nc --argjson s "${n_skills:-0}" --argjson p "${n_plugins:-0}" --argjson a "${n_agents:-0}" --argjson c "${n_cmds:-0}" '{skills:$s,plugins:$p,agents:$a,commands:$c}')"

if [ "$DRY" -eq 1 ]; then
  echo "--- DRY RUN: manifest built, not published ---" >&2
  echo "manifest: $MD" >&2
  emit "$(jq -nc \
    --arg md "$MD" --arg js "$JSON" --argjson sc "$SCOPE_JSON" --argjson rd "${REDACTIONS:-0}" \
    '{ok:true, mode:"dry-run", scope_counts:$sc, redactions:$rd, manifest_md:$md, manifest_json:$js, share_url:null, raw_url:null, dry_run:true}')"
  exit 0
fi

command -v gh >/dev/null 2>&1 || fail_json "gh CLI not installed (brew install gh); manifest kept at $MD"
gh auth status >/dev/null 2>&1 || fail_json "gh not authenticated (gh auth login); manifest kept at $MD"

SHARE_URL=""
RAW_URL=""
MODE=""
if [ -n "$REPO" ]; then
  MODE="repo:$REPO"
  TMPD="$(mktemp -d)"
  ( cd "$TMPD" \
    && git init -q \
    && cp "$MD" claude-setup.md && cp "$JSON" claude-setup.json \
    && git add -A \
    && git -c user.email=teamagent@local -c user.name=teamagent commit -q -m "share: claude setup manifest ${GEN_AT}" ) \
    || fail_json "failed to build local repo commit"
  if gh repo view "$REPO" >/dev/null 2>&1; then :; else
    gh repo create "$REPO" --public -d "Claude Code setup manifest (teamagent-share)" >/dev/null 2>&1 \
      || fail_json "gh repo create $REPO failed"
  fi
  ( cd "$TMPD" && git branch -M main \
    && git remote add origin "https://github.com/${REPO}.git" \
    && git push -q -u origin main --force ) \
    || fail_json "git push to $REPO failed"
  SHARE_URL="https://github.com/${REPO}"
  RAW_URL="https://raw.githubusercontent.com/${REPO}/main/claude-setup.md"
else
  MODE="gist${VIS:+:public}"
  OUT_TXT=""
  for attempt in 1 2 3; do
    OUT_TXT="$(gh gist create "$MD" "$JSON" $VIS --desc "Claude Code setup manifest (teamagent-share) ${GEN_AT}" 2>&1)" || true
    SHARE_URL="$(printf '%s\n' "$OUT_TXT" | grep -oE 'https://gist\.github\.com/[^[:space:]]+' | head -n1)"
    [ -n "$SHARE_URL" ] && break
    sleep $((attempt * 2))
  done
  [ -n "$SHARE_URL" ] || fail_json "gh gist create failed after 3 attempts; manifest kept at $MD"
  GID="${SHARE_URL##*/}"
  LOGIN="$(printf '%s\n' "$SHARE_URL" | sed -E 's|^https://gist\.github\.com/([^/]+)/.*$|\1|')"
  RAW_URL="https://gist.githubusercontent.com/${LOGIN}/${GID}/raw/claude-setup.md"
fi

echo "shared: $SHARE_URL" >&2
emit "$(jq -nc \
  --arg mode "$MODE" --argjson sc "$SCOPE_JSON" --argjson rd "${REDACTIONS:-0}" \
  --arg md "$MD" --arg js "$JSON" --arg su "$SHARE_URL" --arg ru "$RAW_URL" \
  '{ok:true, mode:$mode, scope_counts:$sc, redactions:$rd, manifest_md:$md, manifest_json:$js, share_url:$su, raw_url:$ru, dry_run:false}')"
exit 0
